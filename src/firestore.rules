rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. PUBLIC MARKETS
    // Anyone browsing the app can read the data. 
    // ONLY logged-in users (Google/Phone) can upload a crop, product, or service.
    match /crops/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /daily_products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. USER PROFILES
    // Anyone can read a profile (to see seller details).
    // Users can ONLY edit or delete their own specific profile data.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. SECURE FALLBACK
    // If a hacker tries to create a random new collection (like /fake_data/), block it.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}