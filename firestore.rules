rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. PROFILES ---
    // Consumer Profiles: Only the logged-in consumer can view or edit their private data.
    match /consumer_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Seller Profiles: Publicly visible to consumers, but strictly only editable by the specific seller.
    match /seller_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- STOREFRONTS ---
    // Storefront document IDs are random (SIN-... or ORG-...). We verify ownership via the internal userId field.
    match /organisation_storefront/{sellerId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /individual_storefront/{sellerId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // --- 2. SELLER APPROVALS & ADMIN ---
    // Applications are readable by everyone so the Admin page (no Firebase Auth) can load them.
    // Only authenticated sellers can create or update their own application.
    // Deletes are allowed for both the seller and the admin (admin has no Firebase Auth).
    match /seller_applications/{sellerId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if true; // Admin (no Firebase Auth) must be able to approve/reject/mark-deleted
      allow delete: if true; // Admin and seller must be able to delete
    }
    
    // System config: admin can write (admin has no Firebase auth so we allow all for now)
    match /system_config/{document=**} {
      allow read, write: if true;
    }
    
    // Market Rates: Public to read. Only an Admin can update.
    match /market_rates/{document=**} {
      allow read: if true;
      allow write: if false; 
    }

    // --- 3. THE 6 SELLER LISTINGS ---
    // Public to view. When creating or updating a listing, the attached 'userId' MUST match the logged-in user's UID.
    match /listings_farm_fresh/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /listings_machinery/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /listings_workers/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /listings_business/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /listings_freelancing/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /listings_local_goods/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /seller_listings/{document=**} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}