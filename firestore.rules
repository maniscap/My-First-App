rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. PROFILES ---
    // Anyone can read profiles, but only the owner can write to them
    match /consumer_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /seller_profiles/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // --- 2. SELLER APPROVALS & ADMIN ---
    match /seller_applications/{document=**} {
      allow read, write: if true;
    }
    match /market_rates/{document=**} {
      allow read, write: if true;
    }

    // --- 3. THE 6 SELLER LISTINGS ---
    // Anyone can view listings, but sellers will write to them
    match /listings_farm_fresh/{document=**} {
      allow read, write: if true;
    }
    match /listings_machinery/{document=**} {
      allow read, write: if true;
    }
    match /listings_workers/{document=**} {
      allow read, write: if true;
    }
    match /listings_business/{document=**} {
      allow read, write: if true;
    }
    match /listings_freelancing/{document=**} {
      allow read, write: if true;
    }
    match /listings_local_goods/{document=**} {
      allow read, write: if true;
    }
  }
}