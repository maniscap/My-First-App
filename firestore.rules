rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read the public markets, but only logged-in users can post
    match /crops/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /daily_products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users can only edit their own profile info
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}