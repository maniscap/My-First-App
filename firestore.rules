rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read the public markets, but only logged-in users can post
    match /crops/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /daily_products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users can only view or edit their own profile info to protect GPS/address privacy
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders collection: Contains shipping addresses & GPS. Only the buyer and seller can access.
    match /orders/{orderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.buyerId;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
    }

    // Leads / Interests collection: Created when a consumer clicks "I am interested"
    match /leads/{leadId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.buyerId;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
    }
  }
}